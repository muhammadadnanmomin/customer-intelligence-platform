# Copy this file to .env and fill in your values.

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=customer_intelligence
POSTGRES_USER=cip_user
POSTGRES_PASSWORD=your_secure_password_here

# Application
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Streamlit
STREAMLIT_SERVER_PORT=8501
