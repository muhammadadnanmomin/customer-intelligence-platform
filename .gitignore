# ============================================================
# Customer Intelligence Platform — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# --- Virtual Environments ---
.venv/
venv/
ENV/
env/
.env
!.env.example

# --- Jupyter Notebooks ---
.ipynb_checkpoints/
*.ipynb_checkpoints/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# --- OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Data Files ---
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
*.csv
*.xlsx
*.xls
*.parquet
*.feather
*.h5
*.hdf5
*.db
*.sqlite

# --- Model Artifacts ---
models/churn/*
models/clv/*
models/segmentation/*
!models/churn/.gitkeep
!models/clv/.gitkeep
!models/segmentation/.gitkeep
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# --- Logs ---
logs/*
!logs/.gitkeep
*.log

# --- Reports (generated) ---
reports/figures/*
reports/metrics/*
reports/business_reports/*
!reports/figures/.gitkeep
!reports/metrics/.gitkeep
!reports/business_reports/.gitkeep

# --- Docker ---
*.env.local

# --- Misc ---
.cache/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
coverage.xml
*.cover
